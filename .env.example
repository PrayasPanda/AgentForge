# ── Provider selection ────────────────────────────────────────────────────────
# Choose: anthropic (default) or ollama
LLM_PROVIDER=anthropic

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Ollama LOCAL ──────────────────────────────────────────────────────────────
# Use when LLM_PROVIDER=ollama and Ollama is running on this machine.
# Install: https://ollama.com  →  then: ollama pull llama3.2
#
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2
# (no API key needed for local)

# ── Ollama CLOUD ──────────────────────────────────────────────────────────────
# Use when LLM_PROVIDER=ollama and connecting to a remote/cloud Ollama server.
# Any OpenAI-compatible cloud endpoint works (self-hosted, Groq, Together AI, etc.)
#
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=https://your-cloud-host/v1
# OLLAMA_MODEL=llama3.2
# OLLAMA_API_KEY=your_real_cloud_api_key_here

# -- Gemini -- 

# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza...your_key_here
# GEMINI_MODEL=gemini-2.0-flash